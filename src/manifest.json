{
  "manifest_version": 2,
  "name": "Better Color Picker",
  "version": "1.0.0",
  "description": "Custom color picker for color inputs with advanced features",

  "permissions": ["<all_urls>", "storage"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["picker.css"],
      "run_at": "document_start"
    }
  ]
}
